# Copy to .env and adjust. All settings prefixed LEARNSTACK_.
LEARNSTACK_JWT_SECRET=generate-a-long-random-string
# LEARNSTACK_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/learnstack
LEARNSTACK_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LEARNSTACK_MAX_UPLOAD_MB=500
# Public web origin — printed on certificate PDFs as the verify link.
# Set to your real domain in production (e.g. https://app.yourdomain.com).
LEARNSTACK_FRONTEND_URL=http://localhost:3000

# Object storage for uploaded lesson media (video/audio/images/files).
# In docker-compose this points at the bundled minio service; set to a
# real S3-compatible endpoint (bucket must already exist) if you're not
# running the bundled MinIO container.
LEARNSTACK_MINIO_ENDPOINT=localhost:9000
LEARNSTACK_MINIO_ACCESS_KEY=learnstack
LEARNSTACK_MINIO_SECRET_KEY=change-me-in-production
LEARNSTACK_MINIO_BUCKET=learnstack-media
LEARNSTACK_MINIO_SECURE=false
